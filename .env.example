# Optional PaperLite catalog overrides
# Copy this file to .env for local, Docker Compose, or systemd deployments.
# When serving from paperlite/, PaperLite also falls back to the parent repo .env.
PAPERLITE_SOURCES_PATH=
PAPERLITE_ENDPOINTS_PATH=
PAPERLITE_PROFILES_PATH=
PAPERLITE_TRANSLATION_PROFILES_PATH=
PAPERLITE_TAXONOMY_PATH=
PAPERLITE_HEALTH_SNAPSHOT_PATH=

# Optional SQLite cache location for manual daily crawl storage
# Defaults to .paperlite/paperlite.sqlite3 in the current working directory
PAPERLITE_DB_PATH=
PAPERLITE_CRAWL_COOLDOWN_SECONDS=600
PAPERLITE_CRAWL_SOURCE_DELAY_SECONDS=2
PAPERLITE_ENRICH_TIMEOUT_SECONDS=6
PAPERLITE_SCHEDULE_MIN_INTERVAL_MINUTES=15
PAPERLITE_SCHEDULER_POLL_SECONDS=30
PAPERLITE_SCHEDULER_ENABLED=true

# PaperLite does not ship a default account system in this pass.
# For public VPS deployments, put admin actions behind a reverse proxy auth layer.
# Required only when exporting local preference training data.
PAPERLITE_TRAINING_EXPORT_TOKEN=

# Optional OpenAI-compatible LLM client for manual filter/explain/translate.
# DeepSeek users only need DEEPSEEK_API_KEY; PaperLite then defaults to
# https://api.deepseek.com + deepseek-chat.
# Other providers use PAPERLITE_LLM_API_KEY plus base URL/model.
DEEPSEEK_API_KEY=
PAPERLITE_LLM_PROVIDER=deepseek
PAPERLITE_LLM_BASE_URL=
PAPERLITE_LLM_API_KEY=
PAPERLITE_LLM_MODEL=

# Optional OpenAI-compatible embedding client for explicit metadata RAG and /daily/related
# Used only by explicit RAG/related actions; not used on page load.
PAPERLITE_EMBEDDING_BASE_URL=
PAPERLITE_EMBEDDING_API_KEY=
PAPERLITE_EMBEDDING_MODEL=

# Optional Zotero metadata sync
ZOTERO_API_KEY=
ZOTERO_LIBRARY_TYPE=user
ZOTERO_LIBRARY_ID=
ZOTERO_COLLECTION_KEY=
